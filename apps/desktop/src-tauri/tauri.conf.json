{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codecity",
  "version": "0.0.0",
  "identifier": "com.codecity.app",
  "build": {
    "beforeDevCommand": "pnpm --filter @codecity/web dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "pnpm --filter @codecity/web build",
    "frontendDist": "../../apps/web/.next/server"
  },
  "app": {
    "windows": [
      {
        "title": "Codecity",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
