# Authentication (via magnova-auth)
SKIP_AUTH=true                  # Set to false in production

# GitHub (fallback server token — user's own token is preferred)
GITHUB_TOKEN=

# Inngest
INNGEST_EVENT_KEY=              # From inngest.com dashboard
INNGEST_SIGNING_KEY=            # From inngest.com dashboard

# Upstash Redis (auto-populated by Vercel integration)
KV_REST_API_URL=
KV_REST_API_TOKEN=
