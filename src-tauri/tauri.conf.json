{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CodeCity",
  "version": "0.1.0",
  "identifier": "com.codecity.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:3000/dashboard",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "title": "CodeCity",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "endpoints": [
        "https://github.com/MagnovaAI/codecity/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJFQ0E3RkY4M0Y0MDE3OEMKUldTTUYwQS8rSC9Ldml4Tm1XZGpQTUV5MHBiMzF6VEZoTGNITm9BRXBmOWQxSEVwNWdTRDhUVUkK"
    }
  }
}
